# Copy to .env. Never commit .env.

PAPER_TRADE=true
LOG_LEVEL=INFO

BSC_PROVIDER_URL=
AGENT_WALLET_ADDRESS=
WALLET_ADDRESS=

# CDP API keys for x402 facilitator (Base mainnet). ACCESS_* aliases are supported.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
ACCESS_ID=
ACCESS_SECRET=

# Optional CMC Agent Hub MCP/x402 adapter. Disabled by default; Keyless remains primary.
CMC_MCP_ENABLED=false
CMC_MCP_SHADOW_MODE=false
CMC_MCP_URL=https://mcp.coinmarketcap.com/x402/mcp
# Market data: dual mode (default live with x402 signer) refreshes trial REST every
# LOOP_SECONDS and paid x402 enrichment every CMC_SNAPSHOT_TTL_SECONDS.
USE_DUAL_MARKET_DATA=true
CMC_KEYLESS_SNAPSHOT_TTL_SECONDS=300
# Legacy keyless-only path (full trial snapshot, single TTL). Do not combine with dual.
USE_KEYLESS_PRIMARY=false
# CMC_API_KEY=  # optional; trial REST works without it (better rate limits with key)
# Official x402 SDK payment settings (Base mainnet / CDP settlement on CMC server).
# CMC_X402_EPHEMERAL_KEY signs micropayments; TWAK wallet stays separate.
CMC_X402_EPHEMERAL_KEY=
# EVM_PRIVATE_KEY=
CMC_X402_AMOUNT=0.01
CMC_X402_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
CMC_X402_CHAIN_ID=8453
# Refresh CMC snapshot at most this often; trading loop stays on LOOP_SECONDS.
CMC_SNAPSHOT_TTL_SECONDS=14400

# Optional local-only wallet unlock. Prefer TWAK keychain.
# TWAK_WALLET_PASSWORD=

# Optional overrides are in src/config/settings.py.

# Strategy: production uses the momentum breakout engine.
STRATEGY_MODE=breakout

# Live deployment
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
HEALTH_CHECK_PORT=8080
LOG_ROTATE_MAX_MB=50
DISK_GUARD_MIN_FREE_BYTES=500000000

# Optional market snapshot collector (parallel, non-blocking)
CMC_COLLECTOR_ENABLED=true
CMC_COLLECTOR_INTERVAL_MIN=15
# Whether the collector also pays for x402 technicals (RSI/MACD). Keep FALSE:
# the collector enriches the WHOLE tradable universe, so enabling this roughly
# doubles paid x402 calls per run and can starve the quote-refresh budget. The
# live trading loop still gets RSI via X402_FETCH_TECHNICALS (scoped to top
# candidates). Set explicitly to false in production so the safe default is
# never accidentally overridden.
CMC_COLLECTOR_FETCH_TECHNICALS=false

# Pre-live funding thresholds
MIN_BNB_GAS=0.05
MIN_USDC_BALANCE=50

# RWEAL Phase 1 -- Real-World Event Awareness Layer (entry-only event gate).
# Disabled by default; setting ENABLE_RWEAL=false is a zero-behaviour-change
# no-op. See docs/RWEAL-phase1.md.
ENABLE_RWEAL=false
RWEAL_EVENTS_PATH=events.json
# Presence of this file on disk = manual full-stop (blocks ALL entries AND the
# daily-minimum compliance trade). Create it to halt; delete it to resume.
RWEAL_CONTROL_FILE=TRADING_HALT
# Block discretionary entries this many hours before a scheduled event...
RWEAL_BLACKOUT_HORIZON_HOURS=6
# ...and this many minutes after (unless the event sets its own blackout_minutes).
RWEAL_POST_EVENT_MINUTES=60
