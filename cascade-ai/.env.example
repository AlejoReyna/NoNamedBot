# Copy to .env. Never commit .env.

PAPER_TRADE=true
LOG_LEVEL=INFO

BSC_PROVIDER_URL=
AGENT_WALLET_ADDRESS=
WALLET_ADDRESS=

ACCESS_ID=
ACCESS_SECRET=

# Optional CMC Agent Hub MCP/x402 adapter. Disabled by default; Keyless remains primary.
CMC_MCP_ENABLED=false
CMC_MCP_SHADOW_MODE=true
CMC_MCP_URL=https://mcp.coinmarketcap.com/x402/mcp
# TWAK-native x402 settings. TWAK signs locally; no x402 private key belongs in .env.
CMC_X402_AMOUNT=0.01
CMC_X402_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Optional local-only wallet unlock. Prefer TWAK keychain.
# TWAK_WALLET_PASSWORD=

# Optional overrides are in src/config/settings.py.

# Strategy: "breakout" (legacy 6-factor) or "scalping" (weighted score 0-100)
STRATEGY_MODE=scalping
